#include <stdio.h>
#include <stdlib.h>
struct node
{
int data;
struct node * next;
};
typedef struct node*NODE;

// Create a new node
NODE createNode(int x)
{
    NODE newNode;
    newNode = (NODE)malloc(sizeof(struct node));

    if (newNode == NULL)
    {
        printf("Memory allocation failed\n");
        return NULL;
    }

    newNode->data = x;
    newNode->next = NULL;

    return newNode;
}

// Add node at the end of the list
NODE addNode(NODE first, int x)
{
    NODE newNode = createNode(x);

    if (newNode == NULL)
        return first;

    // If list is empty
    if (first == NULL)
        return newNode;

    NODE temp = first;

    while (temp->next != NULL)
    {
        temp = temp->next;
    }

    temp->next = newNode;

    return first;
}

// Concatenate second list to first list
NODE concatenate(NODE t1, NODE t2)
{
    // If first list is empty
    if (t1 == NULL)
        return t2;

    // If second list is empty
    if (t2 == NULL)
        return t1;

    NODE temp = t1;

    while (temp->next != NULL)
    {
        temp = temp->next;
    }

    temp->next = t2;

    return t1;
}

// Display the list
void displayList(NODE first)
{
    NODE temp = first;

    while (temp != NULL)
    {
        printf("%d --> ", temp->data);
        temp = temp->next;
    }

    printf("NULL\n");
}
